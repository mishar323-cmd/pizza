# YooKassa (live or test merchant)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=

# Telegram order notifications (optional — leave empty to disable)
TG_BOT_TOKEN=
TG_CHAT_ID=

# Postgres password (used by docker-compose for db + DATABASE_URL)
POSTGRES_PASSWORD=pizza_dev_pw

# DATABASE_URL — overridden by docker-compose; only needed when running backend outside compose.
# Example: postgres://pizza:pizza_dev_pw@localhost:5432/pizza?sslmode=disable
DATABASE_URL=

# JWT secret — generate with `openssl rand -base64 32`.
# If empty, backend generates random secret on each restart (all sessions invalidated).
JWT_SECRET=

# Initial admin seeded on first run (only if no admins exist yet).
ADMIN_LOGIN=admin
ADMIN_PASSWORD=
ADMIN_NAME=Администратор

# Backend port (optional, default 8080)
PORT=8080

# CORS — set only if frontend served from different origin (dev cross-port).
# In prod (nginx same-origin), leave empty.
ALLOW_ORIGIN=
